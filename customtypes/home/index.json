{
  "format": "page",
  "id": "home",
  "label": "Home",
  "repeatable": false,
  "status": true,
  "json": {
    "Main": {
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": ""
        }
      },
      "highlighted_projects": {
        "type": "Group",
        "config": {
          "label": "Highlighted projects",
          "repeat": true,
          "fields": {
            "projects": {
              "type": "Link",
              "config": {
                "label": "Projects",
                "select": "document",
                "repeat": false,
                "customtypes": [
                  {
                    "id": "project",
                    "fields": [
                      "image",
                      "title",
                      "year",
                      "description",
                      {
                        "id": "tags",
                        "fields": ["title"]
                      }
                    ]
                  }
                ]
              }
            }
          }
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {}
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      }
    }
  }
}
